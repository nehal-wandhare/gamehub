{
  "name": "frontend",
  "version": "0.1.0",
  "private": true,
  "proxy": "http://backend:5000",

  "dependencies": {
    "@testing-library/dom": "^10.4.1",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@testing-library/user-event": "^13.5.0",
    "react": "^18.2.0",
    "react-dom": "^18.2.0",
    "react-scripts": "5.0.1",
    "serve": "^14.2.6",
    "socket.io-client": "^4.8.3",
    "web-vitals": "^2.1.4"
  },

  "devDependencies": {
    "jest-html-reporter": "^3.10.0"
  },

  "scripts": {
    "start": "react-scripts start",
    "build": "react-scripts build",
    "test": "react-scripts test --coverage --watchAll=false --reporters=default --reporters=jest-html-reporter",
    "eject": "react-scripts eject"
  },

  "jest": {
    "coverageReporters": ["cobertura", "lcov", "text", "html"]
  },

  "jest-html-reporter": {
    "pageTitle": "GameHub Test Dashboard",
    "outputPath": "coverage/test-report.html",
    "includeFailureMsg": true,
    "includeConsoleLog": true
  },

  "eslintConfig": {
    "extends": [
      "react-app",
      "react-app/jest"
    ]
  }
}
